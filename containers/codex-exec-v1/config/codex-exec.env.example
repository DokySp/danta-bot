CODEX_HOME=/codex-home
STATE_DIR=/state
WORKSPACE_DIR=/workspace
SCHEDULE_FILE=/app/config/schedules.yaml
PORTFOLIO_FILE=/app/config/portfolio.txt
DEFAULT_TRADE_PROMPT_FILE=/app/config/default-trade-prompt
TZ=Asia/Seoul

TELEGRAM_GATEWAY_URL=http://telegram-gateway:8080/sendMessage
TELEGRAM_TYPING_INTERVAL_SECONDS=4

CODEX_MODEL=gpt-5.5
CODEX_REASONING_EFFORT=xhigh
CODEX_TIMEOUT_SECONDS=3600
CODEX_BYPASS_APPROVALS_AND_SANDBOX=true
NEW_SESSION_PROMPT=새 대화 시작. 지금 이 응답에 안녕하세요. 새로운 대화를 시작해볼까요? 라고 간단하게 응답.
BUNDLED_SKILLS_DIR=/app/skills
CODEX_SYNC_SKILLS=true
CODEX_SYNC_SKILLS_ONCE=true
CODEX_SYNC_SKILLS_OVERWRITE=false

CODEX_EXEC_HOST=0.0.0.0
CODEX_EXEC_PORT=8080
SCHEDULER_POLL_SECONDS=15
LOG_LEVEL=INFO

CODEX_MCP_SERVER_NAME=kis-trade-mcp
CODEX_MCP_COMMAND=npx
CODEX_MCP_ARGS_TOML=["-y","mcp-remote","http://kis-trade-mcp:3000/sse","--allow-http"]
CODEX_MCP_ENABLED=true
CODEX_MCP_TRADING_ENV=paper
