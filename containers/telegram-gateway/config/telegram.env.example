# Copy this file to telegram-gateway/config/telegram-<route>.env and reference it from
# telegram-gateway/config/routes.yaml under routes.<route>.env_file.
# Real bot tokens should not be committed into this repository.
TELEGRAM_BOT_TOKEN=replace_with_new_bot_token

# Only these Telegram chat IDs can trigger codex-exec routing.
TELEGRAM_ALLOWED_CHAT_IDS=0000000000
TELEGRAM_DEFAULT_CHAT_ID=0000000000

# Matches the curl example's parse_mode=MarkdownV2.
TELEGRAM_PARSE_MODE=MarkdownV2

# Set true only for echo tests. Normal codex-exec routing requires false.
TELEGRAM_ECHO_MODE=false

LOG_LEVEL=INFO
HTTP_TIMEOUT=10
TELEGRAM_POLL_TIMEOUT=25
TELEGRAM_POLL_INTERVAL=1
TELEGRAM_ACK_TEXT=
